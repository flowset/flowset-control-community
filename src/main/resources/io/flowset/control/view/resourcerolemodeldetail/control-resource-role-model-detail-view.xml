<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://io.jmix.securityflowui.view.resourcerole/resourceRoleModelDetailView.title"
      messagesGroup="io.jmix.securityflowui.view.resourcerole"
      extends="io/jmix/securityflowui/view/resourcerole/resource-role-model-detail-view.xml">
    <data>
        <instance id="roleModelDc"
                  class="io.jmix.security.model.ResourceRoleModel">
            <collection id="resourcePoliciesDc" property="resourcePolicies"/>
        </instance>
        <collection id="childRolesDc" class="io.jmix.security.model.ResourceRoleModel"/>
    </data>
    <layout>
        <vbox id="contentBox">
            <tabSheet id="tabSheet" themeNames="bordered hide-scroll-buttons" classNames="box-border"/>
        </vbox>
        <hbox id="detailActions"
              classNames="px-m py-s bg-base">
        </hbox>
    </layout>
</view>