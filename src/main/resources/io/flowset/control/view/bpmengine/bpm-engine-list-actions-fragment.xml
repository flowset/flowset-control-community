<fragment xmlns="http://jmix.io/schema/flowui/fragment">
    <data readOnly="true">
        <instance id="bpmEngineDc" class="io.flowset.control.entity.engine.BpmEngine"/>
        <collection id="bpmEnginesDc" provided="true">
            <loader id="bpmEnginesDl"/>
        </collection>
    </data>
    <actions>
        <action id="markAsDefaultAction" type="control_markAsDefaultEngine"/>
    </actions>
    <content>
        <hbox id="bpmEngineActionsBox" padding="false" themeNames="spacing-s" width="min-content" classNames="pt-s pb-s">
            <button id="markAsDefaultBtn" title="msg:///actions.MarkAsDefault" themeNames="tertiary-inline" visible="false"
                    action="markAsDefaultAction"/>
        </hbox>
    </content>
</fragment>