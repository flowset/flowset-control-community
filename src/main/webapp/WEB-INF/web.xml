<?xml version="1.0" encoding="UTF-8"?>
<!--
    Servlet deployment descriptor for WildFly / external servlet container.

    Key responsibilities:
      1. Mark all servlets as async-supported so Vaadin @Push (Atmosphere
         WebSocket / long-polling) works correctly under Undertow.
      2. Set session timeout and cookie name consistent with application.properties.
      3. Spring Boot's DispatcherServlet is registered automatically via
         SpringBootServletInitializer — no explicit <servlet> mapping needed here.
-->
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0"
         metadata-complete="false">

    <display-name>Flowset Control Community</display-name>

    <!--
        DispatcherServlet is NOT declared here.
        Spring Boot's DispatcherServletAutoConfiguration registers it
        programmatically via DispatcherServletRegistrationBean with
        async-supported=true — an explicit <servlet> block would cause
        "Failed to register 'servlet dispatcherServlet'. Possibly already
        registered?" at startup.
    -->

    <!-- ── Session ─────────────────────────────────────────────────────── -->
    <session-config>
        <!-- Matches server.servlet.session.timeout in application.properties -->
        <session-timeout>30</session-timeout>
        <cookie-config>
            <!-- Matches CONTROL_JSESSION from application.properties -->
            <name>CONTROL_JSESSION</name>
            <http-only>true</http-only>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <!-- ── Welcome file ─────────────────────────────────────────────────── -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>
